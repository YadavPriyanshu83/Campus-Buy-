# Copy this file to .env and fill values before running the backend
# MongoDB connection (already used elsewhere in the project)
MONGO_URI=your_mongo_connection_string

# Server port (optional)
PORT=5000

# SMTP (Gmail) credentials
# - Use your Gmail address for SMTP_EMAIL
# - For Gmail, create an App Password and put it in SMTP_PASS
#   (https://support.google.com/accounts/answer/185833)
SMTP_EMAIL=your@gmail.com
SMTP_PASS=your_gmail_app_password

# Email "from" address shown to recipients (optional)
EMAIL_FROM="Your App <no-reply@yourdomain.com>"

# Where to send feedback emails (defaults to yadavpriyanshu8354@gmail.com)
FEEDBACK_RECIPIENT=yadavpriyanshu8354@gmail.com
